generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum FieldType {
  NUMBER
  SELECT
}

model Category {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String   @unique
  name        String
  description String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Calculator {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  slug              String   @unique
  name              String
  description       String
  formulaPlain      String
  category          String
  /// Optional card image: HTTPS URL or site path e.g. /calculator-images/abc.jpg
  imageUrl          String?
  /// Optional SEO keywords for this calculator (JSON object; edited in admin).
  seo               Json?
  /// Optional admin-authored HTML content shown on the calculator page.
  contentHtml       String?
  /// Longer limitations copy for the article area (inserted after Clinical Significance when present).
  limitationsDetailed String?
  /// JSON: [{ "label": string, "unit": string, "formula": string, "decimals"?: number }]
  outputs           Json
  /// Optional expression that must evaluate to non-zero (same variables as outputs).
  validationExpr    String?
  validationMessage String?
  showOnHome        Boolean  @default(false)
  fields            CalculatorField[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model CalculatorField {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  calculatorId  String      @db.ObjectId
  calculator    Calculator  @relation(fields: [calculatorId], references: [id], onDelete: Cascade)
  sharedFieldId String?     @db.ObjectId
  sharedField   SharedField? @relation(fields: [sharedFieldId], references: [id], onDelete: SetNull)
  key           String
  label         String
  fieldType     FieldType   @default(NUMBER)
  min           Float?
  max           Float?
  step          Float       @default(1)
  defaultValue  Float       @default(0)
  /// JSON: [{ "label": string, "value": number }]
  selectOptions Json?
  /// JSON: [{ "key": string, "label": string, "suffix"?: string, "mul": number, "add"?: number }]
  /// Used for client-side unit switching. Base value stored is (x + add) * mul.
  unitOptions   Json?
  sortOrder     Int         @default(0)

  @@unique([calculatorId, key])
}

/// Reusable input-field definitions for calculator forms (height, weight, sex, etc).
model SharedField {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  slug         String   @unique
  key          String
  label        String
  fieldType    FieldType @default(NUMBER)
  min          Float?
  max          Float?
  step         Float    @default(1)
  defaultValue Float    @default(0)
  /// JSON: [{ "label": string, "value": number }]
  selectOptions Json?
  /// JSON: [{ "key": string, "label": string, "suffix"?: string, "mul": number, "add"?: number }]
  unitOptions  Json?
  description  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  calculatorFields CalculatorField[]
}

/// Reusable unit conversion sets for calculator number fields (same shape as CalculatorField.unitOptions).
model UnitPreset {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  slug        String   @unique
  name        String
  description String?
  /// JSON: [{ "key": string, "label": string, "suffix"?: string, "mul": number, "add"?: number }]
  options     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
